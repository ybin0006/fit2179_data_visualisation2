{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Total Objects Launched into Outer Space",
  "width": 800,
  "height": 400,
  "projection": {
    "type": "equalEarth"
  },
  "params": [
    {
      "name": "Select_Year",
      "value": 2023,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2025,
        "step": 1,
        "name": "Year: "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eaeaea",
        "stroke": "white"
      }
    },
    {
      "data": {
        "url": "data/yearly-number-of-objects-launched-into-outer-space.csv"
      },
      "transform": [
        {
          "filter": "datum.Year == Select_Year"
        },
        {
          "lookup": "Id",
          "from": {
            "data": {
              "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
              "format": {"type": "topojson", "feature": "countries"}
            },
            "key": "id"
          },
          "as": "geo"
        }
      ],
      "mark": {"type": "geoshape", "stroke": "white"},
      "encoding": {
        "shape": {"field": "geo", "type": "geojson"},
        "color": {
          "field": "Annual number of objects launched into outer space",
          "type": "quantitative",
          "title": "Launches",
          "scale": {
            "type": "threshold",
            "domain": [0, 1, 3, 10, 30, 100, 300, 1000],
            "range": ["#ced7e0", "#bfcfd9", "#9ccddc", "#7fb7c7", "#5591a9", "#0b5f7a", "#054569", "#062c43"]
          }
        },
        "tooltip": [
          {"field": "Entity", "type": "nominal", "title": "Country"},
          {"field": "Annual number of objects launched into outer space", "type": "quantitative", "title": "Launches"}
        ]
      }
    }
  ],
  "config": {"background": "#eeede5"}
}