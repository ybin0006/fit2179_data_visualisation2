{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "description": "Interactive line chart with year filter.",

  "data": {
    "url": "data/yearly-number-of-objects-launched-into-outer-space.csv"
  },

  "params": [
    {
      "name": "YearFilter",
      "value": 1960,
      "bind": {
        "input": "range",
        "min": 1957,
        "max": 2023,
        "step": 1,
        "name": "Start Year: "
      }
    }
  ],

  "transform": [
    {
      "filter": "datum.Entity === 'World' || datum.Code === 'OWID_WRL'"
    },
    {
      "filter": "datum.Year >= YearFilter"
    }
  ],

  "width": 400,
  "height": 300,

  "mark": {
    "type": "line",
    "color": "#f8bc04",
    "strokeWidth": 2.5,
    "tooltip": true
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "quantitative",
      "title": "Year"
    },

    "y": {
      "field": "Annual number of objects launched into outer space",
      "type": "quantitative",
      "title": "Objects Launched"
    },

    "tooltip": [
      {
        "field": "Year",
        "type": "quantitative"
      },
      {
        "field": "Annual number of objects launched into outer space",
        "type": "quantitative"
      }
    ]
  }
}