{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Horizontal bar chart of primary mission of objects launched with interactive zoom slider.",
  "data": {
    "url": "data/UCS-Satellite-Database.csv"
  },
  "width": 340, 
  "height": 300,

  "params": [
    {
      "name": "zoomMax",
      "value": 6000,
      "bind": {
        "input": "range",
        "min": 50,
        "max": 6000,
        "step": 50,
        "name": "Zoom X-Axis: "
      }
    }
  ],

  "transform": [
    {
      "aggregate": [
        {
          "op": "count",
          "as": "Count"
        }
      ],
      "groupby": ["Purpose"]
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "rank"
        }
      ],
      "sort": [
        {
          "field": "Count",
          "order": "descending"
        }
      ]
    },
    {
      "filter": "datum.rank <= 10"
    }
  ],

  "encoding": {
    "y": {
      "field": "Purpose",
      "type": "nominal",
      "sort": "-x",
      "title": "Satellite Purpose",
      "axis": {
        "labelFontSize": 8.9,  
        "titleFontSize": 12,  
        "labelLimit": 200     
      }
    }
  },
  "layer": [
    {
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "Count",
          "type": "quantitative",
          "title": "Number of Satellites",
          "scale": {
            "domain": [0, {"expr": "zoomMax"}]
          }
        },
        "color": {
          "field": "Purpose",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["Communications", "Earth Observation", "Technology Development", "Navigation/Global Positioning", "Space Science", "Technology Demonstration", "Earth Science", "Surveillance", "Navigation/Regional Positioning", "Unknown"],
            "range": [
              "#020408",
              "#0b1f3a",
              "#062c43",
              "#054569",
              "#0f5c7a",
              "#146c94",
              "#4f90a8",
              "#9ccddc",
              "#f2c14e",
              "#f8bc04"
            ]
          }
        },
        "tooltip": [
          {"field": "Purpose", "type": "nominal"},
          {"field": "Count", "type": "quantitative"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5
      },
      "encoding": {
        "x": {
          "field": "Count",
          "type": "quantitative"
        },
        "text": {
          "field": "Count",
          "type": "quantitative",
          "format": ","
        }
      }
    }
  ]
}