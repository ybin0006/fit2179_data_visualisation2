{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Horizontal bar chart of primary mission of objects launched with interactive zoom slider.",
  "data": {
    "url": "data/UCS-Satellite-Database.csv"
  },
  "width": 340, 
  "height": 300,

  "params": [
    {
      "name": "zoomMax",
      "value": 6000,
      "bind": {
        "input": "range",
        "min": 50,
        "max": 6000,
        "step": 50,
        "name": "Zoom X-Axis: "
      }
    }
  ],

  "transform": [
    {
      "aggregate": [
        {
          "op": "count",
          "as": "Count"
        }
      ],
      "groupby": ["Purpose"]
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "rank"
        }
      ],
      "sort": [
        {
          "field": "Count",
          "order": "descending"
        }
      ]
    },
    {
      "filter": "datum.rank <= 10"
    }
  ],

  "encoding": {
    "y": {
      "field": "Purpose",
      "type": "nominal",
      "sort": "-x",
      "title": "Purpose",
      "axis": {
        "labelFontSize": 8.9,  
        "titleFontSize": 12,  
        "labelLimit": 200     
      }
    }
  },
  "layer": [
    {
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "Count",
          "type": "quantitative",
          "title": "Objects Launched",
          "scale": {
            "domain": [0, {"expr": "zoomMax"}]
          }
        },
        "color": {
          "field": "Purpose",
          "type": "nominal",
          "legend": null,
          "scale": {
            "range": ["#9ccddc", "#5591a9", "#054569", "#062c43"]
          }
        },
        "tooltip": [
          {"field": "Purpose", "type": "nominal"},
          {"field": "Count", "type": "quantitative"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5
      },
      "encoding": {
        "x": {
          "field": "Count",
          "type": "quantitative"
        },
        "text": {
          "field": "Count",
          "type": "quantitative",
          "format": ","
        }
      }
    }
  ],
    "config": {"background": "#eeede5"}
}